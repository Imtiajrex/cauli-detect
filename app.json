{
  "expo": {
    "name": "Cauli Detect",
    "slug": "cauli-detect",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "owner": "cu-uni",
    "ios": {
      "supportsTablet": true
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "android": {
      "package": "com.anonymous.caulidetect"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "38f4779c-f789-4442-bce2-248b1cb4a7b9"
      }
    }
  }
}
